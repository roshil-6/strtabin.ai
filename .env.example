# ─────────────────────────────────────────────────────
#  Stratabin — Required Environment Variables
# ─────────────────────────────────────────────────────
#
#  FRONTEND (Vercel — set in Project Settings → Environment Variables)
#  Prefix: VITE_  (exposed to the browser bundle)
# ─────────────────────────────────────────────────────

# Clerk publishable key (from Clerk dashboard → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# Backend API URL (your Render service URL, no trailing slash)
VITE_API_URL=https://stratabin-api.onrender.com

# ─────────────────────────────────────────────────────
#  BACKEND (Render — set in Service Settings → Environment)
#  These are NOT prefixed with VITE_ and are server-only
# ─────────────────────────────────────────────────────

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# Allowed CORS origins — comma-separated list of your Vercel URLs
# Example: https://stratabin.com,https://stratabin.vercel.app
ALLOWED_ORIGIN=https://stratabin.com

# Clerk secret key (from Clerk dashboard → API Keys)
# Used for server-side JWT verification
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY_HERE
