# ─────────────────────────────────────────────────────
#  Stratabin — Required Environment Variables
# ─────────────────────────────────────────────────────
#
#  FRONTEND (Vercel — set in Project Settings → Environment Variables)
#  Prefix: VITE_  (exposed to the browser bundle)
# ─────────────────────────────────────────────────────

# Clerk publishable key (from Clerk dashboard → API Keys)
# For username+password login: enable "Username" and "Password" in Clerk Dashboard → User & Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# Backend API URL (your Render service URL, no trailing slash)
# Required for AI (STRAB) to work. For mobile build: set this to your deployed backend.
VITE_API_URL=https://stratabin-api.onrender.com

# ─────────────────────────────────────────────────────
#  BACKEND (Render — set in Service Settings → Environment)
#  These are NOT prefixed with VITE_ and are server-only
# ─────────────────────────────────────────────────────

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# Allowed CORS origins — comma-separated list of your frontend URLs
# stratabin.com and www.stratabin.com are always allowed; add others as needed
# Example: https://stratabin.com,https://www.stratabin.com,https://stratabin.vercel.app
ALLOWED_ORIGIN=https://stratabin.com,https://www.stratabin.com

# Clerk secret key (from Clerk dashboard → API Keys)
# Used for server-side JWT verification
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY_HERE

# Optional: Redis URL (Railway Redis, Upstash, etc.) — shared rate limits + Socket.io across instances
# If unset, rate limits use process memory and realtime stays single-instance only.
# REDIS_URL=redis://default:password@host:6379

# Set to 1 on Render/Railway/Vercel proxy so rate limits use the real client IP (not the proxy)
# TRUST_PROXY=1

# Database: PostgreSQL connection string (Railway/Render Postgres, etc.). When set, SQLite is not used.
# Example: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# SQLite file path (local dev or Render disk). Ignored when DATABASE_URL is set (Postgres is used instead).
# On Render without Postgres: mount a disk and set e.g. DATABASE_PATH=/data/strategybox.db
# DATABASE_PATH=

